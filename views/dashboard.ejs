<%- include('partials/layout-top', { title }) %>
<div class="dashboard-hero card">
  <div class="dashboard-hero__text">
    <h2>Welcome, <span class="accent"><%= user ? user.name : 'User' %></span>!</h2>
    <p class="muted">Manage your OTP services easily.</p>
    <a class="button" href="/buy">Buy New Number</a>
  </div>
</div>

<div class="stat-grid" style="margin-top:16px;">
  <div class="stat-card card">
    <div class="stat-icon">💳</div>
    <div class="stat-value" data-balance>&#8377;<%= Number(user ? user.balance || 0 : 0).toFixed(2) %></div>
    <div class="stat-label">Balance</div>
  </div>
  <div class="stat-card card">
    <div class="stat-icon">➕</div>
    <div class="stat-value">&#8377;<%= Number(typeof totalRecharge !== 'undefined' ? totalRecharge : 0).toFixed(2) %></div>
    <div class="stat-label">Total Recharge</div>
  </div>
  <div class="stat-card card">
    <div class="stat-icon">📱</div>
    <div class="stat-value"><%= typeof totalNumbers !== 'undefined' ? totalNumbers : 0 %></div>
    <div class="stat-label">Numbers</div>
  </div>
</div>

<div class="card" style="margin-top:20px;">
  <h3 style="margin-top:0;">Recent Transactions</h3>
  <% if (transactions.length === 0) { %>
    <p class="muted">No transactions found.</p>
  <% } else { %>
    <table class="table">
      <thead>
        <tr>
          <th>Type</th>
          <th>Amount</th>
          <th>Description</th>
          <th>Date</th>
        </tr>
      </thead>
      <tbody>
        <% transactions.forEach(function(tx){ %>
          <tr>
            <td><span class="badge <%= tx.type %>"><%= tx.type %></span></td>
            <td>&#8377;<%= Number(tx.amount).toFixed(2) %></td>
            <td><%= tx.description %></td>
            <td><%= tx.createdAt.toLocaleString() %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</div>

<script>
  (function(){
    if (!document.querySelector('[data-otp-card]')) return;
    function tickCountdown(card){
      const expires = Number(card.dataset.expires || 0);
      const el = card.querySelector('[data-countdown]');
      if (!expires || !el) return;
      const diff = Math.max(0, expires - Date.now());
      const min = Math.floor(diff / 60000);
      const sec = Math.floor((diff % 60000) / 1000);
      el.textContent = `${String(min).padStart(2,'0')}:${String(sec).padStart(2,'0')}`;
    }

    async function poll(card){
      const id = card.dataset.id;
      const otpEl = card.querySelector('[data-otp]');
      const hidden = card.querySelector('#otp-' + id);
      const cancelBtn = card.querySelector('[data-cancel]');
      const copyBtn = card.querySelector('[data-copy-btn]');
      const resendBtn = card.querySelector('[data-resend]');
      try {
        const res = await fetch(`/api/otp/${id}`);
        const data = await res.json();
        if (data.status === 'received') {
          otpEl.textContent = data.sms || 'Received';
          hidden.textContent = data.sms || '';
          if (cancelBtn) cancelBtn.remove();
          if (copyBtn) copyBtn.style.display = 'inline-block';
          if (resendBtn) resendBtn.remove();
        } else if (data.status === 'cancelled') {
          otpEl.textContent = 'Cancelled';
          if (cancelBtn) cancelBtn.remove();
          if (resendBtn) resendBtn.remove();
        } else {
          otpEl.textContent = 'Waiting...';
          if (resendBtn) resendBtn.style.display = data.canResend ? 'inline-block' : 'none';
        }
      } catch (err) {}
    }

    document.querySelectorAll('[data-otp-card]').forEach((card) => {
      tickCountdown(card);
      setInterval(() => tickCountdown(card), 1000);
      poll(card);
      setInterval(() => poll(card), 3000);

      const cancelBtn = card.querySelector('[data-cancel]');
      if (cancelBtn) {
        cancelBtn.addEventListener('click', async () => {
          cancelBtn.disabled = true;
          await fetch(`/api/cancel/${card.dataset.id}`, { method: 'POST' });
          poll(card);
        });
      }

      const resendBtn = card.querySelector('[data-resend]');
      if (resendBtn) {
        resendBtn.addEventListener('click', async () => {
          resendBtn.disabled = true;
          const original = resendBtn.textContent;
          resendBtn.textContent = 'Requesting...';
          try {
            const res = await fetch(`/api/resend/${card.dataset.id}`, { method: 'POST' });
            if (!res.ok) {
              const data = await res.json().catch(() => ({}));
              throw new Error(data.error || 'Resend failed');
            }
            resendBtn.textContent = 'Requested';
            setTimeout(() => {
              resendBtn.textContent = original;
              resendBtn.disabled = false;
            }, 5000);
          } catch (err) {
            resendBtn.textContent = 'Failed';
            setTimeout(() => {
              resendBtn.textContent = original;
              resendBtn.disabled = false;
            }, 2000);
          }
        });
      }
    });
  })();
</script>

<%- include('partials/layout-bottom') %>

