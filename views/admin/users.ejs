<%- include('../partials/layout-top', { title }) %>
<div class="card">
  <h3 style="margin-top:0;">Users</h3>
  <% if (users.length === 0) { %>
    <p class="muted">No users.</p>
  <% } else { %>
    <table class="table">
      <thead>
        <tr>
          <th>Name</th>
          <th>Email</th>
          <th>Balance</th>
          <th>Status</th>
          <th>Adjust Balance</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% users.forEach(function(u){ %>
          <tr>
            <td><%= u.name %></td>
            <td><%= u.email %></td>
            <td>&#8377;<%= Number(u.balance).toFixed(2) %></td>
            <td><%= u.isActive ? 'Active' : 'Suspended' %></td>
            <td>
              <form method="post" action="/admin/users/balance/<%= u._id %>" style="display:flex; gap:6px; align-items:center;">
                <input class="input" type="number" step="0.01" name="amount" placeholder="Amount" required />
                <select class="select" name="action">
                  <option value="add">Add</option>
                  <option value="deduct">Deduct</option>
                </select>
                <button class="button outline" type="submit">Apply</button>
              </form>
            </td>
            <td>
              <form method="post" action="/admin/users/toggle/<%= u._id %>">
                <button class="button danger" type="submit"><%= u.isActive ? 'Suspend' : 'Activate' %></button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</div>
<%- include('../partials/layout-bottom') %>

